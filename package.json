{
  "name": "aid-oneclick",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "catalog:dev": "node ./apps/catalog/src/server.js",
    "catalog:start": "node ./apps/catalog/src/server.js",
    "catalog:docker:build": "docker build -t aid-oneclick-catalog ./apps/catalog",
    "extension:hint": "echo Load ./apps/extension as an unpacked Chrome extension."
  }
}
