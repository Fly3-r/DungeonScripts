{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aid-oneclick.local/schemas/package-manifest.schema.json",
  "title": "AID One-Click Package Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "description",
    "author",
    "thumbnailUrl",
    "sharedLibrary",
    "onInput",
    "onModelContext",
    "onOutput",
    "minInstallerVersion",
    "hash"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "thumbnailUrl": {
      "type": "string",
      "minLength": 1
    },
    "sharedLibrary": {
      "type": "string"
    },
    "onInput": {
      "type": "string"
    },
    "onModelContext": {
      "type": "string"
    },
    "onOutput": {
      "type": "string"
    },
    "minInstallerVersion": {
      "type": "string",
      "minLength": 1
    },
    "hash": {
      "type": "string",
      "minLength": 1
    }
  }
}
