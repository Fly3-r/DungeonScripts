{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aid-oneclick.local/schemas/package-submission.schema.json",
  "title": "AID One-Click Package Submission",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "submissionId",
    "status",
    "createdAt",
    "updatedAt",
    "package",
    "contact",
    "review"
  ],
  "properties": {
    "submissionId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected",
        "needs_changes"
      ]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "version",
        "description",
        "author",
        "authorProfileUrl",
        "sharedLibrary",
        "onInput",
        "onModelContext",
        "onOutput",
        "minInstallerVersion"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "author": {
          "type": "string",
          "minLength": 1
        },
        "authorProfileUrl": {
          "type": "string",
          "minLength": 1,
          "format": "uri"
        },
        "thumbnailUrl": {
          "type": "string",
          "minLength": 1
        },
        "sharedLibrary": {
          "type": "string"
        },
        "onInput": {
          "type": "string"
        },
        "onModelContext": {
          "type": "string"
        },
        "onOutput": {
          "type": "string"
        },
        "minInstallerVersion": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "contact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "discordUsername"
      ],
      "properties": {
        "discordUsername": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewer",
        "reviewedAt",
        "notes"
      ],
      "properties": {
        "reviewer": {
          "type": [
            "string",
            "null"
          ]
        },
        "reviewedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "publishedManifestFile": {
      "type": "string",
      "minLength": 1
    },
    "publishedHash": {
      "type": "string",
      "minLength": 1
    }
  }
}
