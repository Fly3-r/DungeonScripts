# Local development defaults
CATALOG_PORT=3000
PUBLIC_BASE_URL=http://127.0.0.1:3000
DEFAULT_MIN_INSTALLER_VERSION=1.0.0
CATALOG_RUNTIME_BIND_PATH=./apps/catalog/data/runtime
CATALOG_PACKAGES_BIND_PATH=./apps/catalog/data/packages
CATALOG_SCRIPTS_BIND_PATH=./apps/catalog/data/scripts

